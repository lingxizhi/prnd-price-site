---
import Layout from '../layouts/Layout.astro';
import PriceCard from '../components/PriceCard.astro';
import StatsBar from '../components/StatsBar.astro';
import PriceTable from '../components/PriceTable.astro';
import prices from '../data/prices.json';
import { fmtDate } from '../utils/format';

const SITE_URL = 'https://prnd-price-site.vercel.app';

const latest = prices[prices.length - 1];
const prev = prices.length > 1 ? prices[prices.length - 2] : latest;

// 图表数据：日期格式化为展示格式，价格保持原始元/吨
const chartData = {
  dates: prices.map(p => fmtDate(p.date)),
  metal: prices.map(p => p.metalPrNd),
  oxide: prices.map(p => p.oxidePrNd),
  waste: prices.map(p => p.wastePrNd),
};
---

<Layout
  title="镨钕价格监控系统 - 稀土PrNd实时行情"
  description="实时追踪金属镨钕、氧化镨钕、废料镨钕价格走势，覆盖2025年12月至今全部工作日数据。"
  canonicalUrl={SITE_URL}
>
  <div class="container">
    <header>
      <h1>📊 镨钕价格监控系统</h1>
      <p class="subtitle">PrNd Price Monitoring System · 最近更新 {fmtDate(latest.date)}</p>
    </header>

    <PriceCard label="金属镨钕" price={latest.metalPrNd} prevPrice={prev.metalPrNd} />
    <PriceCard label="氧化镨钕" price={latest.oxidePrNd} prevPrice={prev.oxidePrNd} />
    <PriceCard label="废料镨钕" price={latest.wastePrNd} prevPrice={prev.wastePrNd} />

    <StatsBar prices={prices} />

    <section class="chart-section">
      <div class="section-header">
        <h2>📈 价格走势</h2>
        <div class="chart-tabs">
          <button class="tab active" data-range="all">全部</button>
          <button class="tab" data-range="30">近30天</button>
          <button class="tab" data-range="90">近90天</button>
        </div>
      </div>
      <div id="chart" style="width:100%;height:420px;"></div>
    </section>

    <section class="table-section">
      <h2>📋 历史数据</h2>
      <PriceTable prices={prices} />
    </section>

    <footer>
      <p>数据来源：稀土行业公众号 · 每工作日更新 · 共 {prices.length} 条记录</p>
    </footer>
  </div>

  <script>
    import { initChart } from '../utils/chart';
    const chartData = JSON.parse(document.getElementById('chart-data')!.textContent!);
    initChart('chart', chartData);
  </script>

  <!-- 图表数据注入（SSR输出，客户端读取） -->
  <script type="application/json" id="chart-data" set:html={JSON.stringify(chartData)} />

  <style>
    .container { max-width: 960px; margin: 0 auto; padding: 20px 16px; }

    /* 头部 */
    header { text-align: center; margin-bottom: 28px; }
    header h1 { font-size: 1.6rem; font-weight: 700; letter-spacing: 1px; }
    .subtitle { color: #64748b; margin-top: 6px; font-size: 0.85rem; }

    /* 价格卡片网格 - 覆盖组件内部布局 */
    :global(.cards) { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }

    /* 图表区域 */
    .chart-section { margin-bottom: 24px; }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .section-header h2 { font-size: 1rem; }
    .chart-tabs { display: flex; gap: 6px; }
    .tab {
      padding: 4px 12px; border-radius: 6px; border: 1px solid #334155;
      background: transparent; color: #94a3b8; font-size: 0.75rem; cursor: pointer;
      transition: all 0.2s;
    }
    .tab:hover { border-color: #475569; }
    .tab.active { background: #334155; color: #e2e8f0; border-color: #475569; }
    #chart { background: #1e293b; border-radius: 14px; border: 1px solid #293548; padding: 8px; }

    /* 表格区域 */
    .table-section { margin-bottom: 24px; }
    .table-section h2 { font-size: 1rem; margin-bottom: 12px; }

    /* 页脚 */
    footer { text-align: center; color: #475569; font-size: 0.75rem; padding: 20px 0; border-top: 1px solid #1e293b; margin-top: 8px; }

    /* 响应式 */
    @media (max-width: 640px) {
      :global(.cards) { grid-template-columns: 1fr; }
      .card-value { font-size: 1.5rem; }
      .section-header { flex-direction: column; gap: 8px; align-items: flex-start; }
    }
  </style>
</Layout>
