---
import Layout from '../layouts/Layout.astro';
import PriceCardGrid from '../components/PriceCardGrid.astro';
import prices from '../data/prices.json';
import { fmtDate, calcChange } from '../utils/format';

const len = prices.length;
const latest = prices[len - 1];
const prev = len > 1 ? prices[len - 2] : latest;

// 多维度涨跌幅：7个数据点前 / 30个数据点前 / 年初至今
const prev7 = len > 7 ? prices[len - 8] : prices[0];
const prev30 = len > 30 ? prices[len - 31] : prices[0];
const ytdIndex = prices.findIndex(p => p.date.startsWith('2026'));
const ytd = ytdIndex >= 0 ? prices[ytdIndex] : prices[0];

// 计算多维度涨跌（金属镨钕）
const chg7d = calcChange(latest.metalPrNd, prev7.metalPrNd);
const chg30d = calcChange(latest.metalPrNd, prev30.metalPrNd);
const chgYtd = calcChange(latest.metalPrNd, ytd.metalPrNd);

// 图表数据：日期格式化为展示格式，价格保持原始元/吨
const chartData = {
  dates: prices.map(p => fmtDate(p.date)),
  metal: prices.map(p => p.metalPrNd),
  oxide: prices.map(p => p.oxidePrNd),
  waste: prices.map(p => p.wastePrNd),
};

// 年份对比数据
const yearGroups: Record<string, { monthDay: string; metal: number; oxide: number; waste: number }[]> = {};
prices.forEach(p => {
  const [y, m, d] = p.date.split('-');
  if (!yearGroups[y]) yearGroups[y] = [];
  yearGroups[y].push({ monthDay: `${parseInt(m)}/${parseInt(d)}`, metal: p.metalPrNd, oxide: p.oxidePrNd, waste: p.wastePrNd });
});
const yearKeys = Object.keys(yearGroups).sort();
// 用最近一年的日期做对齐基准
const refYear = yearKeys[yearKeys.length - 1];
const compareLabels = yearGroups[refYear].map(p => p.monthDay);
const compareData = {
  labels: compareLabels,
  years: yearKeys,
  metal: yearKeys.map(y => yearGroups[y].map(p => p.metal)),
  oxide: yearKeys.map(y => yearGroups[y].map(p => p.oxide)),
  waste: yearKeys.map(y => yearGroups[y].map(p => p.waste)),
};
---

<Layout
  title="镨钕价格监控系统 - 稀土PrNd实时行情"
  description="实时追踪金属镨钕、氧化镨钕、废料镨钕价格走势，覆盖2025年12月至今全部工作日数据。"
>
  <div class="container">
    <header>
      <h1>📊 镨钕价格监控系统</h1>
      <p class="subtitle">PrNd Price Monitoring System · 最近更新 {fmtDate(latest.date)}</p>
    </header>

    <PriceCardGrid latest={latest} prev={prev} prev7={prev7} prev30={prev30} ytd={ytd} />

    <section class="chart-section">
      <div class="section-header">
        <h2>📈 价格走势</h2>
        <div class="chart-tabs">
          <button class="tab active" data-range="all">全部</button>
          <button class="tab" data-range="7">近7天</button>
          <button class="tab" data-range="30">近30天</button>
          <button class="tab" data-range="90">近90天</button>
          <button class="tab" data-range="compare">年份对比</button>
        </div>
      </div>
      <div id="chart" class="responsive-chart"></div>
    </section>

    <footer>
      <p>数据来源：稀土行业公众号 · 每工作日更新 · 共 {prices.length} 条记录</p>
    </footer>
  </div>

  <!-- 数据注入（先于消费方） -->
  <script type="application/json" id="chart-data" set:html={JSON.stringify(chartData)} />
  <script type="application/json" id="compare-data" set:html={JSON.stringify(compareData)} />

  <!-- 图表初始化（读取上方 chart-data） -->
  <script>
    import { initChart } from '../utils/chart';
    const el = document.getElementById('chart-data');
    const compareEl = document.getElementById('compare-data');
    if (el) {
      const chartData = JSON.parse(el.textContent!);
      const compareData = compareEl ? JSON.parse(compareEl.textContent!) : null;
      initChart('chart', chartData, compareData);
    }
  </script>

  <style>
    .container { max-width: 960px; margin: 0 auto; padding: 20px 16px; }

    /* 头部 */
    header { text-align: center; margin-bottom: 28px; }
    header h1 { font-size: 1.6rem; font-weight: 700; letter-spacing: 1px; }
    .subtitle { color: #64748b; margin-top: 6px; font-size: 0.85rem; }

    /* 图表区域 */
    .chart-section { margin-bottom: 24px; }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .section-header h2 { font-size: 1rem; }
    .chart-tabs { display: flex; gap: 6px; }
    .tab {
      padding: 4px 12px; border-radius: 6px; border: 1px solid #334155;
      background: transparent; color: #94a3b8; font-size: 0.75rem; cursor: pointer;
      transition: all 0.2s;
    }
    .tab:hover { border-color: #475569; }
    .tab.active { background: #334155; color: #e2e8f0; border-color: #475569; }
    
    .responsive-chart { width: 100%; height: 480px; }
    #chart { background: #1e293b; border-radius: 14px; border: 1px solid #293548; padding: 8px; box-sizing: border-box; }

    /* 页脚 */
    footer { text-align: center; color: #475569; font-size: 0.75rem; padding: 20px 0; border-top: 1px solid #1e293b; margin-top: 8px; }

    /* 响应式 */
    @media (max-width: 640px) {
      .section-header { flex-direction: column; gap: 8px; align-items: flex-start; }
      .responsive-chart { height: 60vh; min-height: 380px; }
    }
  </style>
</Layout>
