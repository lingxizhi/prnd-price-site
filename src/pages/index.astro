---
import Layout from '../layouts/Layout.astro';
import prices from '../data/prices.json';

const latest = prices[prices.length - 1];
const prev = prices.length > 1 ? prices[prices.length - 2] : latest;

function fmt(n: number) {
  return n.toLocaleString('zh-CN');
}

function change(cur: number, old: number) {
  const diff = cur - old;
  const pct = ((diff / old) * 100).toFixed(2);
  return { diff, pct, up: diff >= 0 };
}

const metalChg = change(latest.metalPrNd, prev.metalPrNd);
const oxideChg = change(latest.oxidePrNd, prev.oxidePrNd);
const wasteChg = change(latest.wastePrNd, prev.wastePrNd);

const dates = JSON.stringify(prices.map(p => p.date));
const metalData = JSON.stringify(prices.map(p => p.metalPrNd));
const oxideData = JSON.stringify(prices.map(p => p.oxidePrNd));
const wasteData = JSON.stringify(prices.map(p => p.wastePrNd));
---

<Layout title="镨钕价格监控系统">
  <div class="container">
    <header>
      <h1>📊 镨钕价格监控系统</h1>
      <p class="subtitle">PrNd Price Monitoring System</p>
      <p class="update-time">最近更新：{latest.date}</p>
    </header>

    <section class="cards">
      <div class="card">
        <div class="card-label">金属镨钕</div>
        <div class="card-value">{fmt(latest.metalPrNd)}<span class="unit">元/吨</span></div>
        <div class:list={['card-change', metalChg.up ? 'up' : 'down']}>
          {metalChg.up ? '▲' : '▼'} {Math.abs(metalChg.diff).toLocaleString('zh-CN')}元 ({metalChg.pct}%)
        </div>
      </div>
      <div class="card">
        <div class="card-label">氧化镨钕</div>
        <div class="card-value">{fmt(latest.oxidePrNd)}<span class="unit">元/吨</span></div>
        <div class:list={['card-change', oxideChg.up ? 'up' : 'down']}>
          {oxideChg.up ? '▲' : '▼'} {Math.abs(oxideChg.diff).toLocaleString('zh-CN')}元 ({oxideChg.pct}%)
        </div>
      </div>
      <div class="card">
        <div class="card-label">废料镨钕</div>
        <div class="card-value">{fmt(latest.wastePrNd)}<span class="unit">元/吨</span></div>
        <div class:list={['card-change', wasteChg.up ? 'up' : 'down']}>
          {wasteChg.up ? '▲' : '▼'} {Math.abs(wasteChg.diff).toLocaleString('zh-CN')}元 ({wasteChg.pct}%)
        </div>
      </div>
    </section>

    <section class="chart-section">
      <h2>📈 价格走势</h2>
      <div id="chart" style="width:100%;height:450px;"></div>
    </section>

    <section class="table-section">
      <h2>📋 历史数据</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>日期</th><th>金属镨钕(元/吨)</th><th>氧化镨钕(元/吨)</th><th>废料镨钕(元/吨)</th></tr>
          </thead>
          <tbody>
            {[...prices].reverse().map(p => (
              <tr>
                <td>{p.date}</td>
                <td>{fmt(p.metalPrNd)}</td>
                <td>{fmt(p.oxidePrNd)}</td>
                <td>{fmt(p.wastePrNd)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <footer>
      <p>数据来源：稀土行业公众号 · 每工作日更新 · 共 {prices.length} 条记录</p>
    </footer>
  </div>

  <script is:inline src="/echarts.min.js"></script>
  <script is:inline define:vars={{ dates, metalData, oxideData, wasteData }}>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof echarts === 'undefined') {
        document.getElementById('chart').innerHTML = '<p style="text-align:center;color:#94a3b8;padding:40px;">图表加载失败，请刷新页面</p>';
        return;
      }
      const chart = echarts.init(document.getElementById('chart'), 'dark');
      chart.setOption({
        backgroundColor: 'transparent',
        tooltip: {
          trigger: 'axis',
          formatter: function(params) {
            let s = params[0].axisValue + '<br/>';
            params.forEach(p => {
              s += p.marker + p.seriesName + ': ' + p.value.toLocaleString() + ' 元/吨<br/>';
            });
            return s;
          }
        },
        legend: { data: ['金属镨钕', '氧化镨钕', '废料镨钕'], top: 10, textStyle: { color: '#94a3b8' } },
        grid: { left: 80, right: 30, top: 50, bottom: 50 },
        xAxis: {
          type: 'category',
          data: dates,
          axisLabel: { rotate: 45, fontSize: 10, color: '#94a3b8' },
          axisLine: { lineStyle: { color: '#334155' } }
        },
        yAxis: {
          type: 'value',
          name: '元/吨',
          nameTextStyle: { color: '#94a3b8' },
          axisLabel: {
            color: '#94a3b8',
            formatter: function(v) { return (v / 10000).toFixed(0) + '万'; }
          },
          splitLine: { lineStyle: { color: '#1e293b' } }
        },
        series: [
          {
            name: '金属镨钕', type: 'line', data: metalData, smooth: true,
            lineStyle: { width: 2 }, itemStyle: { color: '#f97316' },
            areaStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: 'rgba(249,115,22,0.15)' }, { offset: 1, color: 'rgba(249,115,22,0)' }] } }
          },
          {
            name: '氧化镨钕', type: 'line', data: oxideData, smooth: true,
            lineStyle: { width: 2 }, itemStyle: { color: '#38bdf8' },
            areaStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: 'rgba(56,189,248,0.15)' }, { offset: 1, color: 'rgba(56,189,248,0)' }] } }
          },
          {
            name: '废料镨钕', type: 'line', data: wasteData, smooth: true,
            lineStyle: { width: 2 }, itemStyle: { color: '#a78bfa' },
            areaStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: 'rgba(167,139,250,0.15)' }, { offset: 1, color: 'rgba(167,139,250,0)' }] } }
          }
        ],
        dataZoom: [
          { type: 'inside', start: 0, end: 100 },
          { type: 'slider', height: 20, bottom: 5, borderColor: '#334155', fillerColor: 'rgba(56,189,248,0.15)', handleStyle: { color: '#38bdf8' } }
        ]
      });
      window.addEventListener('resize', () => chart.resize());
    });
  </script>

  <style>
    .container { max-width: 960px; margin: 0 auto; padding: 24px 16px; }
    header { text-align: center; margin-bottom: 32px; }
    header h1 { font-size: 1.8rem; font-weight: 700; }
    .subtitle { color: #94a3b8; margin-top: 4px; font-size: 0.9rem; }
    .update-time { color: #64748b; margin-top: 8px; font-size: 0.85rem; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }
    .card {
      background: #1e293b; border-radius: 12px; padding: 20px; text-align: center;
      border: 1px solid #334155; transition: border-color 0.2s;
    }
    .card:hover { border-color: #38bdf8; }
    .card-label { color: #94a3b8; font-size: 0.85rem; margin-bottom: 8px; }
    .card-value { font-size: 1.6rem; font-weight: 700; }
    .unit { font-size: 0.75rem; color: #94a3b8; margin-left: 4px; }
    .card-change { font-size: 0.8rem; margin-top: 6px; }
    .card-change.up { color: #22c55e; }
    .card-change.down { color: #ef4444; }
    .chart-section, .table-section { margin-bottom: 32px; }
    .chart-section h2, .table-section h2 { font-size: 1.1rem; margin-bottom: 16px; }
    #chart { background: #1e293b; border-radius: 12px; border: 1px solid #334155; }
    .table-wrap { overflow-x: auto; max-height: 500px; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    th { background: #1e293b; padding: 10px 12px; text-align: right; position: sticky; top: 0; z-index: 1; }
    th:first-child { text-align: left; }
    td { padding: 8px 12px; border-bottom: 1px solid #1e293b; text-align: right; }
    td:first-child { text-align: left; color: #94a3b8; }
    tbody tr:hover { background: #1e293b; }
    footer { text-align: center; color: #64748b; font-size: 0.8rem; padding: 24px 0; }
    @media (max-width: 640px) {
      .cards { grid-template-columns: 1fr; }
      .card-value { font-size: 1.3rem; }
    }
  </style>
</Layout>
