---
import PriceCard from './PriceCard.astro';

interface PriceEntry {
  date: string;
  metalPrNd: number;
  oxidePrNd: number;
  wastePrNd: number;
}

interface Props {
  latest: PriceEntry;
  prev: PriceEntry;
  prev7: PriceEntry;
  prev30: PriceEntry;
  ytd: PriceEntry;
}

const { latest, prev, prev7, prev30, ytd } = Astro.props;
---

<section class="cards">
  <PriceCard label="金属镨钕" price={latest.metalPrNd} prevPrice={prev.metalPrNd} prevPrice7={prev7.metalPrNd} prevPrice30={prev30.metalPrNd} ytdPrice={ytd.metalPrNd} />
  <PriceCard label="氧化镨钕" price={latest.oxidePrNd} prevPrice={prev.oxidePrNd} prevPrice7={prev7.oxidePrNd} prevPrice30={prev30.oxidePrNd} ytdPrice={ytd.oxidePrNd} />
  <PriceCard label="废料镨钕" price={latest.wastePrNd} prevPrice={prev.wastePrNd} prevPrice7={prev7.wastePrNd} prevPrice30={prev30.wastePrNd} ytdPrice={ytd.wastePrNd} />
</section>

<style>
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }
  @media (max-width: 640px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
